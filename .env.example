# PostgreSQL 설정 (Docker)
DB_HOST=localhost
DB_PORT=15432
DB_NAME=threat_intel
DB_USER=admin
DB_PASSWORD=admin123

# LLM 설정 (OpenAI-compatible API)
# 예시: Ollama (http://localhost:11434/v1)
# 예시: LM Studio (http://localhost:1234/v1)
# 예시: vLLM (http://localhost:8000/v1)
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=kimi-k2.6
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=60

# Agent safety limits
MAX_SQL_RETRIES=2
QUERY_TIMEOUT_MS=5000
MAX_RESULT_ROWS=500
MAX_QUESTION_LENGTH=1000
USE_LANGGRAPH=true

# LangSmith tracing (optional)
LANGSMITH_TRACING=false
LANGSMITH_TRACING_V2=false
LANGCHAIN_TRACING_V2=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=threat-analysis-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Vanna Text-to-SQL
USE_VANNA=true
VANNA_PERSIST_DIR=./vanna_chroma
VANNA_TRAINING_DIR=./training
VANNA_AUTO_TRAIN=true
